# CloudBox Backend — copy to .env and fill in your values

# Application
APP_NAME=CloudBox API
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Default cloud provider for provisioning (contabo | digitalocean | aws — only contabo implemented)
DEFAULT_PROVIDER=contabo

# Auth & database
DATABASE_URL=sqlite:///./cloudbox.db
JWT_SECRET=generate-a-long-random-secret-here
JWT_EXPIRE_MINUTES=10080

# Contabo API credentials (Customer Control Panel → API)
# https://api.contabo.com/
CONTABO_CLIENT_ID=
CONTABO_CLIENT_SECRET=
CONTABO_API_USER=
CONTABO_API_PASSWORD=
CONTABO_API_BASE_URL=https://api.contabo.com
CONTABO_AUTH_URL=https://auth.contabo.com/auth/realms/contabo/protocol/openid-connect/token

# Namecheap API — https://www.namecheap.com/support/api/intro/
# Enable API access and whitelist your server IPv4 in Namecheap profile → Tools → API Access
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=
NAMECHEAP_SANDBOX=true

# Default registrant contact (required for domain registration via API)
NAMECHEAP_CONTACT_FIRST_NAME=
NAMECHEAP_CONTACT_LAST_NAME=
NAMECHEAP_CONTACT_ADDRESS1=
NAMECHEAP_CONTACT_CITY=
NAMECHEAP_CONTACT_STATE=
NAMECHEAP_CONTACT_POSTAL_CODE=
NAMECHEAP_CONTACT_COUNTRY=US
# Format required by Namecheap: +NNN.NNNNNNNNNN (e.g. +250.787490069 or +1.5555555555)
NAMECHEAP_CONTACT_PHONE=
NAMECHEAP_CONTACT_EMAIL=
NAMECHEAP_CONTACT_ORGANIZATION=

# Future providers (not wired yet)
# DIGITALOCEAN_API_TOKEN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-central-1
